{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Research Workspace",
  "version": "0.1.0",
  "identifier": "com.research.workspace",
  "build": {
    "beforeDevCommand": "python3 -m http.server 14377 --bind 127.0.0.1 --directory viewer-dist",
    "beforeBuildCommand": "",
    "frontendDist": "viewer-dist",
    "devUrl": "http://127.0.0.1:14377/"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../app",
      "../templates",
      "../static",
      "../requirements.txt"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "shortDescription": "Personal research and source workspace",
    "longDescription": "Local-first workspace for categories, subtopics, resources, questions, and writing."
  },
  "plugins": {}
}
